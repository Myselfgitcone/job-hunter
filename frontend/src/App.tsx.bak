import { useState, useEffect, useCallback } from "react";
import {
  Briefcase, Settings as SettingsIcon, RefreshCw, Loader2, User,
  LayoutDashboard, Columns, List, Clock, Sparkles,
} from "lucide-react";
import type { Job, JobStatus } from "./types";
import { api } from "./api";
import { checkVisa } from "./utils/visaCheck";
import { isLevelMatch } from "./utils/levelCheck";
import { JobList } from "./components/JobList";
import { JobDetail } from "./components/JobDetail";
import { Settings } from "./components/Settings";
import { Dashboard } from "./components/Dashboard";
import { Kanban } from "./components/Kanban";
import { QuickTailor } from "./components/QuickTailor";
import { Profile } from "./components/Profile";
import type { QualifyResult } from "./types";

type View     = "jobs" | "settings" | "dashboard" | "profile";
type JobsMode = "list" | "kanban";
type Filter   = { status: string; remote: string; country: string; source: string; time_range: string };

const COUNTRIES = [
  { label: "All Countries", value: "" },
  { label: "USA",           value: "USA" },
  { label: "India",         value: "India" },
  { label: "Remote",        value: "Remote" },
];

const SOURCES = [
  "Greenhouse", "Lever", "Ashby", "Workday", "BambooHR", "Recruitee", "Google", "Apple", "Meta", "Netflix", "HiringCafe",
];

const STATUS_OPTIONS = [
  { value: "",          label: "All",       dot: "bg-slate-500" },
  { value: "new",       label: "New",       dot: "bg-slate-400" },
  { value: "applied",   label: "Applied",   dot: "bg-blue-500"  },
  { value: "interview", label: "Interview", dot: "bg-green-500" },
  { value: "skipped",   label: "Skipped",   dot: "bg-slate-700" },
];

const TIME_OPTIONS = [
  { value: "",    label: "All Time"  },
  { value: "24h", label: "Last 24h" },
  { value: "48h", label: "Last 48h" },
  { value: "7d", label: "Last 7 days" },
];

const SEL = [
  "w-full text-xs bg-slate-800/80 border border-slate-700 text-slate-200",
  "rounded-lg px-2.5 py-2 cursor-pointer focus:outline-none focus:border-blue-500",
  "hover:border-slate-600 transition-colors",
].join(" ");

function timeAgo(iso: string): string {
  if (!iso) return "";
  try {
    const diff = Date.now() - new Date(iso).getTime();
    const m = Math.floor(diff / 60000);
    if (m < 1)  return "just now";
    if (m < 60) return `${m}m ago`;
    const h = Math.floor(m / 60);
    if (h < 24) return `${h}h ago`;
    return `${Math.floor(h / 24)}d ago`;
  } catch { return ""; }
}

export default function App() {
  const [view,          setView]          = useState<View>("jobs");
  const [jobsMode,      setJobsMode]      = useState<JobsMode>("list");
  const [jobs,          setJobs]          = useState<Job[]>([]);
  const [allJobs,       setAllJobs]       = useState<Job[]>([]);
  const [selectedId,    setSelectedId]    = useState<string | null>(null);
  const [loading,       setLoading]       = useState(false);
  const [scraping,      setScraping]      = useState(false);
  const [scrapeMsg,     setScrapeMsg]     = useState("");
  const [lastScrapedAt, setLastScrapedAt] = useState<string>("");
  const [showQuickTailor, setShowQuickTailor] = useState(false);
  const [filter, setFilter] = useState<Filter>({
    status: "", remote: "", country: "", source: "", time_range: "",
  });

  useEffect(() => {
    api.getSettings().then(s => {
      setLastScrapedAt((s as any).last_scraped_at || "");
    }).catch(() => {});
  }, []);

  const loadAllJobs = useCallback(async () => {
    try {
      const raw = await api.getJobs();
      setAllJobs(raw.filter(j =>
        checkVisa(j.title + " " + (j.description || "")).eligible &&
        isLevelMatch(j.title)
      ));
    } catch {}
  }, []);

  const loadJobs = useCallback(async () => {
    setLoading(true);
    try {
      const p: Record<string, string | boolean> = {};
      if (filter.status)              p.status     = filter.status;
      if (filter.remote === "true")   p.remote     = true;
      if (filter.remote === "false")  p.remote     = false;
      if (filter.country)             p.country    = filter.country;
      if (filter.source)              p.source     = filter.source;
      if (filter.time_range)          p.time_range = filter.time_range;
      const raw = await api.getJobs(p as any);
      setJobs(raw.filter(j =>
        checkVisa(j.title + " " + (j.description || "")).eligible &&
        isLevelMatch(j.title)
      ));
    } catch (e: any) { console.error(e); }
    finally { setLoading(false); }
  }, [filter]);

  useEffect(() => { loadJobs(); },    [loadJobs]);
  useEffect(() => { loadAllJobs(); }, [loadAllJobs]);

  const handleScrape = async () => {
    setScraping(true); setScrapeMsg("");
    try {
      const r = await api.scrape();
      const msg = `+${r.new_jobs} new`;
      setScrapeMsg(msg);
      setLastScrapedAt(r.scraped_at || new Date().toISOString());
      await loadJobs(); await loadAllJobs();
    } catch (e: any) { setScrapeMsg(e.message); }
    finally { setScraping(false); }
  };

  const handleClearAll = async () => {
    if (!confirm("Delete ALL jobs from the database? This cannot be undone.")) return;
    try {
      const r = await api.clearAllJobs();
      setScrapeMsg(`Cleared ${r.deleted} jobs`);
      setJobs([]); setAllJobs([]); setSelectedId(null);
    } catch (e: any) { setScrapeMsg(e.message); }
  };

  const handleStatusChange = async (id: string, status: JobStatus) => {
    await api.setStatus(id, status);
    setJobs(p => p.map(j => j.id === id ? { ...j, status } : j));
    setAllJobs(p => p.map(j => j.id === id ? { ...j, status } : j));
  };

  const refreshJob = async (id: string) => {
    const u = await api.getJob(id);
    setJobs(p => p.map(j => j.id === id ? u : j));
    setAllJobs(p => p.map(j => j.id === id ? u : j));
  };

  const selectedJob = jobs.find(j => j.id === selectedId) ?? null;

  // Interdependent counts
  const jobsForCounts = (excludeCountry = false, excludeSource = false) =>
    allJobs.filter(j =>
      (excludeCountry || !filter.country || j.country === filter.country) &&
      (excludeSource  || !filter.source  || j.source  === filter.source)
    );

  const countryCounts = COUNTRIES.reduce((acc, c) => {
    const base = jobsForCounts(true, false);
    acc[c.value] = c.value === "" ? base.length : base.filter(j => j.country === c.value).length;
    return acc;
  }, {} as Record<string, number>);

  const sourceCounts = SOURCES.reduce((acc, s) => {
    const base = jobsForCounts(false, true);
    acc[s] = base.filter(j => j.source === s).length;
    return acc;
  }, {} as Record<string, number>);

  const statusBase    = jobsForCounts(false, false);
  const statusCounts  = STATUS_OPTIONS.reduce((acc, s) => {
    acc[s.value] = s.value === "" ? statusBase.length : statusBase.filter(j => j.status === s.value).length;
    return acc;
  }, {} as Record<string, number>);

  const hasActiveFilters = !!(filter.country || filter.source || filter.remote || filter.time_range);
  const jobsForSource = jobsForCounts(false, true);

  return (
    <div className="flex h-screen overflow-hidden bg-slate-900 text-slate-100">

      {/* ══ SIDEBAR ═══════════════════════════════════════════════════════════ */}
      <aside className="w-52 flex-shrink-0 bg-slate-950 border-r border-slate-800 flex flex-col overflow-y-auto">

        {/* Brand */}
        <div className="px-4 py-3 border-b border-slate-800 flex-shrink-0">
          <h1 className="text-sm font-bold text-white tracking-wide">Job Hunter</h1>
          <p className="text-[10px] text-slate-500 mt-0.5">Data Engineer</p>
        </div>

        {/* Nav */}
        <div className="px-2.5 pt-3 pb-2 space-y-1 flex-shrink-0">
          {([
            { id: "jobs"      as View, icon: <Briefcase size={14} />,       label: "Jobs" },
            { id: "dashboard" as View, icon: <LayoutDashboard size={14} />, label: "Dashboard" },
          ] as const).map(({ id, icon, label }) => (
            <button key={id} onClick={() => setView(id)}
              className={`w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
                view === id ? "bg-blue-600 text-white" : "text-slate-400 hover:text-white hover:bg-slate-800"
              }`}
            >
              {icon} {label}
            </button>
          ))}

          <button onClick={() => setShowQuickTailor(true)}
            className="w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium transition-colors text-purple-400 hover:text-purple-300 hover:bg-slate-800"
          >
            <Sparkles size={14} /> Quick Tailor
          </button>

          <button onClick={() => setView("settings")}
            className={`w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
              view === "settings" ? "bg-blue-600 text-white" : "text-slate-400 hover:text-white hover:bg-slate-800"
            }`}
          >
            <SettingsIcon size={14} /> Settings
          </button>

          <button onClick={() => setView("profile")}
            className={`w-full flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm font-medium transition-colors ${
              view === "profile" ? "bg-blue-600 text-white" : "text-slate-400 hover:text-white hover:bg-slate-800"
            }`}
          >
            <User size={14} /> My Profile
          </button>
        </div>

        {view === "jobs" && (
          <>
            <div className="mx-3 mt-1 border-t border-slate-800" />

            <div className="px-3 py-3 space-y-4">

              {/* ── Country ── */}
              <div>
                <label className="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Country</label>
                <select value={filter.country} onChange={e => setFilter(f => ({ ...f, country: e.target.value }))} className={SEL}>
                  {COUNTRIES.map(c => {
                    const n = countryCounts[c.value] ?? 0;
                    return <option key={c.value} value={c.value}>{c.label}{n > 0 ? ` (${n})` : ""}</option>;
                  })}
                </select>
              </div>

              {/* ── Location Type ── */}
              <div>
                <label className="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Location Type</label>
                <select value={filter.remote} onChange={e => setFilter(f => ({ ...f, remote: e.target.value }))} className={SEL}>
                  <option value="">Any</option>
                  <option value="true">Remote Only</option>
                  <option value="false">Onsite Only</option>
                </select>
              </div>

              {/* ── Time ── */}
              <div>
                <label className="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Posted Time</label>
                <select value={filter.time_range} onChange={e => setFilter(f => ({ ...f, time_range: e.target.value }))} className={SEL}>
                  {TIME_OPTIONS.map(t => (
                    <option key={t.value} value={t.value}>{t.label}</option>
                  ))}
                </select>
              </div>

              {/* ── Source ── */}
              <div>
                <label className="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Source</label>
                <select value={filter.source} onChange={e => setFilter(f => ({ ...f, source: e.target.value }))} className={SEL}>
                  <option value="">All Sources ({jobsForSource.length})</option>
                  {SOURCES.map(s => {
                    const n = sourceCounts[s] ?? 0;
                    return <option key={s} value={s}>{s} ({n})</option>;
                  })}
                </select>
              </div>

              {/* ── Clear ── */}
              {hasActiveFilters && (
                <button
                  onClick={() => setFilter({ status: "", remote: "", country: "", source: "", time_range: "" })}
                  className="w-full py-1.5 text-[11px] text-slate-500 hover:text-slate-300 border border-slate-700 hover:border-slate-600 rounded-lg transition-colors"
                >
                  Clear All Filters
                </button>
              )}
            </div>

            <div className="mx-3 border-t border-slate-800" />

            {/* ── Status ── */}
            <div className="px-3 py-3">
              <label className="block text-[10px] font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Status</label>
              <div className="space-y-0.5">
                {STATUS_OPTIONS.map(s => {
                  const count  = statusCounts[s.value] ?? 0;
                  const active = filter.status === s.value;
                  return (
                    <button key={s.value} onClick={() => setFilter(f => ({ ...f, status: s.value }))}
                      className={`w-full flex items-center gap-2 px-2.5 py-1.5 rounded-lg text-xs transition-colors ${
                        active ? "bg-slate-700 text-white" : "text-slate-500 hover:text-slate-200 hover:bg-slate-800/70"
                      }`}
                    >
                      <span className={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${s.dot}`} />
                      <span className="flex-1 text-left capitalize">{s.label}</span>
                      <span className={`font-mono tabular-nums text-[10px] ${active ? "text-white" : count > 0 ? "text-slate-400" : "text-slate-700"}`}>
                        {count}
                      </span>
                    </button>
                  );
                })}
              </div>
            </div>
          </>
        )}
      </aside>

      {/* ══ MAIN ══════════════════════════════════════════════════════════════ */}
      <div className="flex-1 flex overflow-hidden">

        {view === "dashboard" ? (
          <div className="flex-1 overflow-y-auto"><Dashboard /></div>

        ) : view === "settings" ? (
          <div className="flex-1 overflow-y-auto p-6"><Settings /></div>

        ) : view === "profile" ? (
          <div className="flex-1 overflow-y-auto p-6"><Profile /></div>

        ) : jobsMode === "kanban" ? (
          <div className="flex-1 flex flex-col overflow-hidden">
            <Topbar scraping={scraping} scrapeMsg={scrapeMsg} lastScrapedAt={lastScrapedAt}
              onScrape={handleScrape} onClear={handleClearAll} jobCount={jobs.length} mode={jobsMode} onMode={setJobsMode} />
            <div className="flex-1 overflow-hidden">
              <Kanban jobs={jobs}
                onStatusChange={(id, s) => handleStatusChange(id, s as JobStatus)}
                onSelect={id => { setSelectedId(id); setJobsMode("list"); }}
              />
            </div>
          </div>

        ) : (
          <>
            <div className="w-[400px] flex-shrink-0 flex flex-col border-r border-slate-800">
              <Topbar scraping={scraping} scrapeMsg={scrapeMsg} lastScrapedAt={lastScrapedAt}
                onScrape={handleScrape} onClear={handleClearAll} jobCount={jobs.length} mode={jobsMode} onMode={setJobsMode} />
              <div className="flex-1 overflow-y-auto">
                {loading ? (
                  <div className="flex items-center justify-center h-32 text-slate-500 text-sm">
                    <Loader2 size={18} className="animate-spin mr-2" /> Loading…
                  </div>
                ) : jobs.length === 0 ? (
                  <div className="p-8 text-center text-slate-500 text-sm">
                    <p className="text-2xl mb-3">🔍</p>
                    <p className="font-medium">No jobs found</p>
                    <p className="mt-1 text-xs text-slate-600">
                      {allJobs.length === 0 ? 'Click "Scrape Now" to fetch jobs.' : "Try adjusting filters or scraping again."}
                    </p>
                  </div>
                ) : (
                  <JobList jobs={jobs} selectedId={selectedId} onSelect={setSelectedId}
                  onQualifyUpdated={(id, r) => {
                    setJobs(prev => prev.map(j => j.id === id ? { ...j, qualify_result: r } : j));
                    setAllJobs(prev => prev.map(j => j.id === id ? { ...j, qualify_result: r } : j));
                  }} />
                )}
              </div>
            </div>

            <div className="flex-1 overflow-y-auto">
              {selectedJob ? (
                <JobDetail job={selectedJob} onStatusChange={handleStatusChange}
                  onTailored={() => refreshJob(selectedJob.id)} />
              ) : (
                <div className="flex flex-col items-center justify-center h-full text-slate-600 gap-2">
                  <Briefcase size={32} className="opacity-20" />
                  <p className="text-sm">Select a job to view details</p>
                </div>
              )}
            </div>
          </>
        )}
      </div>

      {/* Quick Tailor modal */}
      {showQuickTailor && <QuickTailor onClose={() => setShowQuickTailor(false)} />}
    </div>
  );
}

// ── Topbar ────────────────────────────────────────────────────────────────────
function Topbar({ scraping, scrapeMsg, lastScrapedAt, onScrape, onClear, jobCount, mode, onMode }: {
  scraping: boolean; scrapeMsg: string; lastScrapedAt: string;
  onScrape: () => void; onClear: () => void; jobCount: number;
  mode: JobsMode; onMode: (m: JobsMode) => void;
}) {
  const ago = lastScrapedAt ? timeAgo(lastScrapedAt) : null;

  return (
    <div className="px-3 py-2.5 border-b border-slate-800 bg-slate-950/40 flex items-center gap-2 flex-shrink-0">
      <button onClick={onScrape} disabled={scraping}
        className="flex items-center gap-1.5 px-3 py-1.5 bg-blue-600 hover:bg-blue-700 disabled:opacity-50 text-white text-xs rounded-lg font-medium transition-colors"
      >
        {scraping ? <Loader2 size={12} className="animate-spin" /> : <RefreshCw size={12} />}
        {scraping ? "Scraping…" : "Scrape Now"}
      </button>

      <button onClick={onClear} title="Clear all jobs"
        className="px-2.5 py-1.5 text-xs text-slate-500 hover:text-red-400 border border-slate-700 hover:border-red-500/50 rounded-lg transition-colors"
      >
        Clear All
      </button>

      {scrapeMsg &&<span className="text-xs text-green-400 font-medium">{scrapeMsg}</span>}

      {ago && !scrapeMsg && (
        <span className="flex items-center gap-1 text-[11px] text-slate-600">
          <Clock size={10} /> {ago}
        </span>
      )}

      <span className="text-[11px] text-slate-500 font-mono tabular-nums ml-1">
        {jobCount} jobs
      </span>

      <div className="ml-auto flex items-center gap-1 bg-slate-800 rounded-lg p-0.5">
        <button onClick={() => onMode("list")} title="List"
          className={`p-1.5 rounded transition-colors ${mode === "list" ? "bg-slate-600 text-white" : "text-slate-500 hover:text-white hover:bg-slate-700"}`}>
          <List size={13} />
        </button>
        <button onClick={() => onMode("kanban")} title="Kanban"
          className={`p-1.5 rounded transition-colors ${mode === "kanban" ? "bg-slate-600 text-white" : "text-slate-500 hover:text-white hover:bg-slate-700"}`}>
          <Columns size={13} />
        </button>
      </div>
    </div>
  );
}
